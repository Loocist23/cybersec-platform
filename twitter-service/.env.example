# Configuration du Twitter Service

# API Cybersec (pour envoyer les données)
API_URL=http://localhost:8000
TWEETS_ENDPOINT=/tweets/
ACCOUNTS_ENDPOINT=/tweets/accounts/

# snscrape Configuration
MAX_TWEETS_PER_REQUEST=50
MAX_ACCOUNTS_PER_REQUEST=20
REQUEST_DELAY=5  # Délai entre les requêtes (secondes)

# Recherche
SEARCH_QUERIES="cybersecurity,vulnerability,infosec,CVE,malware"
SEARCH_DAYS_BACK=7

# Filtrage
MIN_LIKES=0
MIN_RETWEETS=0
LANGUAGE=en

# Logging
LOG_LEVEL=INFO

# Mode daemon
DAEMON_INTERVAL_HOURS=24

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=30
